// ---------------------------------------------------------------------
// nextflow.config
// This file controls HOW the pipeline runs (containers, resources,
// default file paths). It does NOT contain pipeline logic — that lives
// in main.nf and modules/*.nf.
// ---------------------------------------------------------------------

singularity {
    enabled = true
    autoMounts = true
    cacheDir = "${projectDir}/containers"
}

process {
    executor = 'local'
    errorStrategy = 'retry'
    maxRetries = 1
}

params {
    reads = null
    reference = null
    sample = "sample1"
    outdir = "${launchDir}/results"

    sif_minimap2 = "${projectDir}/containers/minimap2.sif"
    sif_samtools = "${projectDir}/containers/minimap2.sif"
    sif_clair3 = "${projectDir}/containers/clair3.sif"
    model_path = "/opt/models/hifi"
}

profiles {
    standard {
        process.container = "${projectDir}/containers/minimap2.sif"
    }

    test {
        params.reads = "${projectDir}/data/HUCR38.fastq"
        params.reference = "${projectDir}/data/reference.fa"
    }
}

// ---------------------------------------------------------------------
// Added in this fork: execution report / timeline, purely for
// transparency and debugging. Safe to remove if you don't need them.
// ---------------------------------------------------------------------
report {
    enabled = true
    overwrite = true
    file = "${params.outdir}/execution_report.html"
}

timeline {
    enabled = true
    overwrite = true
    file = "${params.outdir}/execution_timeline.html"
}
